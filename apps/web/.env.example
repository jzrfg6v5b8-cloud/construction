# DeepSeek（仅服务端读取；留空时自动使用 MockDeepSeekProvider）
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_COMPLEX_MODEL=deepseek-v4-pro

# Vision Worker（默认本机 8091；不可达时 /api/.../vision/jobs 返回 503，不编造 OCR）
VISION_WORKER_URL=http://127.0.0.1:8091

# CJK PDF 字体（.ttf/.otf）；未设置时回退常见系统路径（如 macOS Arial Unicode）
NOTO_CJK_FONT_PATH=

# Stripe Billing（留空时结账接口返回安全的演示结果；Webhook 未配置 STRIPE_WEBHOOK_SECRET 时返回 503）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRO_PRICE_ID=
STRIPE_BUSINESS_PRICE_ID=
BILLING_PORTAL_TOKEN=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 本地 SQLite（默认 .data/sharkflows.sqlite）
DATABASE_PATH=.data/sharkflows.sqlite

# 会话与 Google OAuth（邮箱密码登录始终可用；Google 需同时配置 CLIENT_ID/SECRET）
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=
EMAIL_FROM=

# 私有对象存储；开发环境使用本地私有目录（OBJECT_STORAGE_DRIVER=s3 时需 AWS 凭证 + S3_BUCKET）
OBJECT_STORAGE_DRIVER=local
OBJECT_STORAGE_PATH=.data/objects
PRIVATE_STORAGE_PATH=.data/private
SIGNED_URL_SECRET=
S3_BUCKET=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto

# 可选生产队列（空 = LocalQueueAdapter；设置后 = BullMQ）
REDIS_URL=

# SketchUp本地桥接回传到Sharkflows的服务端密钥
SKETCHUP_RESULT_WEBHOOK_SECRET=

# 场景 PNG 落盘目录（默认 .data/renders/<projectId>/）
RENDERS_PATH=.data/renders

# 可选外部渲染器（预留；当前落地路径为 SketchUp PNG 上传 / webhook base64）
EXTERNAL_RENDERER_URL=
EXTERNAL_RENDERER_TOKEN=

# 可选报价签章（生产）
QUOTE_SIGNATURE_ENDPOINT=
QUOTE_SIGNATURE_SECRET=
