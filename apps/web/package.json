{
  "name": "@sharkflows/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "postbuild": "node -e \"const fs=require('fs');const p=require('path').join('.next','lock');fs.mkdirSync('.next',{recursive:true});if(!fs.existsSync(p))fs.writeFileSync(p,'');\"",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.3.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sharkflows/processing-queue": "*",
    "@sharkflows/space-schema": "*",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.44.7",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.3",
    "stripe": "^22.3.2",
    "three": "^0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
