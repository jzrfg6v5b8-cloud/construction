    "test:redis": "RUN_REDIS_TESTS=1 vitest run test/bullmq.integration.test.ts"
  },
  "dependencies": {
    "bullmq": "^5",
    "ioredis": "^5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false
}
